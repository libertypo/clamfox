{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "version": "0.0.5.9",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "permissions": [
        "downloads",
        "nativeMessaging",
        "notifications",
        "storage",
        "activeTab",
        "menus",
        "contextMenus",
        "scripting",
        "webRequest",
        "alarms",
        "cookies"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "design_tokens.css",
                "content.css"
            ]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "clamfox@ovidio.me",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "ClamFox",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "web_accessible_resources": []
}