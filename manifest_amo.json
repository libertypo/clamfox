{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "version": "0.0.8.8",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "permissions": [
        "downloads",
        "nativeMessaging",
        "notifications",
        "storage",
        "activeTab",
        "tabs",
        "menus",
        "contextMenus",
        "alarms",
        "webRequest",
        "webRequestBlocking",
        "webNavigation",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "psl_data.js",
                "content.js"
            ],
            "css": [
                "design_tokens.css",
                "content.css"
            ],
            "all_frames": true
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "clamfox@ovidio.me",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "scripts": [
            "psl_data.js",
            "background.js"
        ]
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "ClamFox",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self';"
    }
}