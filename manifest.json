{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "version": "0.0.6.3",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "permissions": [
        "downloads",
        "nativeMessaging",
        "notifications",
        "storage",
        "activeTab",
        "menus",
        "contextMenus",
        "webRequest",
        "alarms",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "clamfox@ovidio.me",
            "strict_min_version": "128.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "ClamFox",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "web_accessible_resources": [],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'none';"
    }
}